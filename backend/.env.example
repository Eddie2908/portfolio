# DevPortfolio API - Environment Variables
# Copy this file to .env and fill in your values

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# JWT (required - generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your-jwt-secret-here

# SMTP Configuration (fallback - Gmail SMTP is blocked on Railway free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
CONTACT_EMAIL=your-email@gmail.com

# Resend Configuration (RECOMMENDED for Railway - HTTP API never blocked)
# Get your API key at: https://resend.com (free tier: 3000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# URLs (update these for production)
ADMIN_URL=http://localhost:5500/admin-dashboard
FRONTEND_URL=http://localhost:3000

# CORS (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# Optional settings
RESET_TOKEN_EXPIRE_MINUTES=60
MAX_UPLOAD_SIZE_MB=5

# Error monitoring (optional - leave empty to disable)
# Get a DSN at https://sentry.io (free tier available)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
